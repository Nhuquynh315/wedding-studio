# ── Flask ──────────────────────────────────────────────────────────────
# REQUIRED — any long random string; used to sign sessions and CSRF tokens
SECRET_KEY=change-me-to-a-long-random-string

# REQUIRED — controls which config class is loaded (development | testing | production)
FLASK_ENV=development

# ── Database ───────────────────────────────────────────────────────────
# OPTIONAL in development (defaults to sqlite:///wedding_studio.db)
# REQUIRED in production
DATABASE_URL=sqlite:///wedding_studio.db

# ── AI — Google Gemini ─────────────────────────────────────────────────
# OPTIONAL — only required to use the AI theme generation feature
# Obtain a key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── macOS / WeasyPrint ──────────────────────────────────────────────────
# WeasyPrint needs Pango/Cairo system libs. uv-managed Python (standalone
# distribution) does not inherit Homebrew's dyld paths the way framework
# Pythons do, so we set it explicitly.
# Apple Silicon: /opt/homebrew/lib   Intel Mac: /usr/local/lib
DYLD_FALLBACK_LIBRARY_PATH=/opt/homebrew/lib
